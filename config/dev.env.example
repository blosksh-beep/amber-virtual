# ============================================================
# 琥珀虚颜 (Amber Virtual) - 开发环境配置
# ============================================================

# --- AI 后端模式 ---
# xiaozhi: 通过小智AI服务器（默认）- 实时语音流，完整的ASR+LLM+TTS流水线
# llm: 直连LLM API - 需要自建ASR/TTS，适合定制化场景
AI_MODE=xiaozhi

# --- 小智AI模式配置 ---
# WebSocket地址（从小智服务器获取或自建）
XIAOZHI_WS_URL=ws://localhost:8000/xiaozhi/v1/
# 鉴权Token（xiaozhi.me注册获取或自建服务器配置）
XIAOZHI_TOKEN=your-xiaozhi-token
# 协议版本 (1=裸OPUS, 2=带时间戳, 3=精简头)
XIAOZHI_PROTOCOL_VERSION=3

# --- LLM直连模式配置 ---
LLM_API_KEY=your-llm-api-key
LLM_ENDPOINT=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat
# ASR配置（LLM模式需要自建语音识别）
ASR_PROVIDER=sensevoice
ASR_ENDPOINT=http://localhost:8001/asr
# TTS配置（LLM模式需要自建语音合成）
TTS_PROVIDER=cosyvoice
TTS_ENDPOINT=http://localhost:8002/tts

# --- 设备控制 ---
MQTT_BROKER=mqtt://localhost:1883
DEVICE_SERVICE_PORT=3001

# --- 服务端口 ---
AI_SERVICE_PORT=3000